import random

def pedir_intento():
  while True:
    Intento = input("\nIngresa un número de 3 dígitos (000-999): ")
    if len(Intento) == 3 and Intento.isdigit():
        return [int(digito) for digito in Intento]
    else:
        print("\nError, volver a intentar")

def pedir_intento2():
  while True:
    Intento = input("\nIngresa un número de 3 dígitos (000-999): ")
    if len(Intento) == 3 and Intento.isdigit():
        return int(Intento)
    else:
        print("\nError, volver a intentar")


Elección = int(input("Elige el modo de juego: \nLa computadora piensa los 3 elementos y el usuario adivina. (1) \nEl usuario piensa los 3 elementos y la computadora adivina. (2)\n"))

while Elección != 1 and Elección != 2:
  print("Error, elige")
  Elección = int(input("1 o 2\n"))

if Elección == 1:
  pcnm = [random.randint(0, 9) for _ in range(3)]
  mia = []
  mia = pedir_intento()
  contador = 0
  historial = []
  while mia != pcnm:
    contador += 1
    for posicion, numero_usuario in enumerate(mia):
      if numero_usuario == pcnm[posicion]:
        print(f"El {numero_usuario} está en la posición correcta (posición {posicion}).")
      elif numero_usuario in pcnm:
        print(f"El {numero_usuario} es correcto, pero está en otra posición.")
      else:
        print(f"El {numero_usuario} no está en la combinación.")
    dato = "".join(map(str, mia))
    historial.append(dato)
    print("\nIntento fallido. Sigue intentando.")
    mia = pedir_intento()
  historia = " otro: ".join(map(str, historial))
  extra = "".join(map(str, pcnm))
  print(f"\nTodos los intentos fueron: {historia}")
  print(f"\nGanaste, la respuesta correcta era: {extra}")
  print(f"\nIntentaste un total de: {contador}")
elif Elección == 2:
  NumSC = pedir_intento2()
  bajo = 0
  alto = 999
  contador = 0
  while True:
    rpts = (bajo + alto) // 2
    contador += 1
    print(f"La computadora intenta: {rpts:03d}")
    if rpts == NumSC:
      break
    elif rpts > NumSC:
      alto = rpts - 1
    else:
      bajo = rpts + 1
  print(f"Tu número es: {rpts:03d}")
  print(f"Mi cantidad de intentos binarios fue: {contador}")